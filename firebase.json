{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/getEmbedding",  "function": "getEmbedding"  },
      { "source": "/api/matchModifier", "function": "matchModifier" },
      { "source": "**",                 "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
