# Azure OpenAI
VITE_AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
VITE_AZURE_OPENAI_API_KEY=your_azure_api_key
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o
VITE_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
VITE_AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Firebase Web App Config
# Firebase Console → 프로젝트 설정 → 내 앱 → 웹 앱 선택 → SDK 설정 및 구성
VITE_FIREBASE_API_KEY=your_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
